{
  "name": "jay-gupta-personal-site",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "prebuild:feeds": "node scripts/fetch-feeds.mjs",
    "prebuild:loop": "node scripts/fetch-loop.mjs",
    "audit:responsive": "node scripts/responsive-audit.mjs",
    "build": "npm run prebuild:feeds && npm run prebuild:loop && tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "framer-motion": "latest",
    "lucide-react": "latest",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@types/react": "18.3.23",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "4.7.0",
    "autoprefixer": "latest",
    "jsdom": "24.1.3",
    "playwright": "^1.60.0",
    "postcss": "latest",
    "tailwindcss": "3.4.17",
    "typescript": "5.9.3",
    "vite": "6.4.3",
    "vitest": "4.1.8"
  }
}
